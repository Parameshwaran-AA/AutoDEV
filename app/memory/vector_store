import faiss
import numpy as np


class VectorStore:

    def __init__(self, dim=1536):
        self.index = faiss.IndexFlatL2(dim)
        self.vectors = []

    def add(self, vector):
        arr = np.array([vector]).astype("float32")
        self.index.add(arr)
        self.vectors.append(vector)

    def search(self, vector, k=3):
        arr = np.array([vector]).astype("float32")
        distances, indices = self.index.search(arr, k)
        return indices
